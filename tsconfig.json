{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": [ "ESNext", "DOM", "DOM.Iterable" ],
		"strict": true,
		"jsx": "preserve",
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": false,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"sourceMap": true,
		"baseUrl": "."
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.js",
		"src/**/*.vue",
		"vite.lib.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
